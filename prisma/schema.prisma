generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum RentalStatus {
  PLACED
  CONFIRMED
  PAID
  PICKED_UP
  RETURNED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

// One table for all 3 roles. The "role" field is what separates a
// Customer from a Provider from an Admin - not separate tables.
// This matches the assignment spec: "Users select their role during registration."
model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // relation name "ProviderGear" disambiguates this from other User relations below
  gearItems GearItem[]    @relation("ProviderGear")
  rentals   RentalOrder[]
  reviews   Review[]

  @@map("users")
}

model Category {
  id        String     @id @default(uuid())
  name      String     @unique
  gearItems GearItem[]

  @@map("categories")
}

model GearItem {
  id          String   @id @default(uuid())
  name        String
  description String
  brand       String
  pricePerDay Float
  quantity    Int      @default(1)
  available   Boolean  @default(true)
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providerId String
  provider   User   @relation("ProviderGear", fields: [providerId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  rentalItems RentalItem[]
  reviews     Review[]

  @@index([categoryId])
  @@index([providerId])
  @@map("gear_items")
}

// The order itself - dates, status, total. Line items live in RentalItem
// so one order can contain multiple different gear items (e.g. tent + 2 sleeping bags).
model RentalOrder {
  id          String       @id @default(uuid())
  status      RentalStatus @default(PLACED)
  startDate   DateTime
  endDate     DateTime
  totalAmount Float
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  items   RentalItem[]
  payment Payment?

  @@index([customerId])
  @@map("rental_orders")
}

model RentalItem {
  id            String @id @default(uuid())
  quantity      Int
  priceAtRental Float // snapshot of pricePerDay at time of booking, so later price changes don't rewrite history

  rentalOrderId String
  rentalOrder   RentalOrder @relation(fields: [rentalOrderId], references: [id])

  gearItemId String
  gearItem   GearItem @relation(fields: [gearItemId], references: [id])

  @@map("rental_items")
}

// One-to-one with RentalOrder: each order has at most one payment record.
model Payment {
  id            String        @id @default(uuid())
  transactionId String        @unique // Stripe session/payment intent id
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  rentalOrderId String      @unique
  rentalOrder   RentalOrder @relation(fields: [rentalOrderId], references: [id])

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  gearItemId String
  gearItem   GearItem @relation(fields: [gearItemId], references: [id])

  @@index([gearItemId])
  @@map("reviews")
}
