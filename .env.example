# Copy this file to .env and fill in real values. Never commit .env itself.

# Postgres connection string (get this from Neon, Railway, or your own Postgres instance)
DATABASE_URL="postgresql://user:password@host:5432/gearup?schema=public"

# Any long random string - used to sign JWTs
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# From your Stripe dashboard (test mode keys while developing)
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

PORT=5000
CLIENT_URL="http://localhost:3000"
